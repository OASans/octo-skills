{
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(*)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:www.man7.org)",
      "WebSearch",
      "Edit(file_path:.claude/skills/**)",
      "Write(file_path:.claude/skills/**)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline-command.sh"
  }
}
